; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GameExpo2"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")

[dotnet]

project/assembly_name="GameExpo2"

[file_customization]

folder_colors={
"res://Assets/": "purple",
"res://ControlsScene/": "gray",
"res://DevelopersScene/": "teal",
"res://MainGame/": "orange",
"res://MainMenu/": "red",
"res://NetworkCore/": "blue",
"res://Player/": "yellow",
"res://Sounds/": "pink"
}
